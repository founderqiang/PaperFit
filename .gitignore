# PaperFit .gitignore
# 排除所有本地数据、编译产物和个人配置

# ============ 运行时数据 ============
data/state.json
data/compile.log
data/pages/
data/evidence/
data/logs/
run/
logs/

# ============ 备份与归档 ============
data/backups/
data/archives/

# ============ Benchmark 私有数据 ============
# benchmarks 目录包含私有测试用例，整个目录排除
data/benchmarks/

# ============ LaTeX 编译产物 ============
*.aux
*.log
*.out
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.toc
*.lof
*.lot
*.nav
*.snm
*.synctex.gz
*.xdv
*.pdf

# ============ macOS 系统文件 ============
.DS_Store
.AppleDouble
.LSOverride
._*

# ============ IDE 与编辑器 ============
.idea/
.vscode/
*.swp
*.swo
*~

# ============ Python ============
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
env/
.env
*.egg-info/
dist/
build/

# ============ Node.js ============
node_modules/
npm-debug.log
yarn-error.log

# ============ Claude Code 本地配置 ============
.claude/settings.local.json
.claude/memory/
.claude/projects/

# ============ 敏感信息 ============
*.pem
*.key
*.crt
.env
.env.local
.env.*.local
secrets/
credentials/
.venv/
internal/

# ============ 临时文件 ============
*.tmp
*.bak
*.temp
*.partial_failed_*
tmp/
temp/

# ============ 诊断报告（可能包含敏感数据）============
diagnostic_report*.md
page_images/page_001.png
page_images/page_002.png
page_images/page_003.png
page_images/page_004.png
page_images/page_005.png
page_images/page_006.png
page_images/page_007.png
page_images/page_008.png
page_images/page_009.png
page_images/page_010.png
page_images/page_011.png
page_images/page_012.png
page_images/page_013.png
page_images/page_014.png
page_images/page_015.png
page_images/page_016.png
page_images/page_017.png
page_images/page_018.png
scripts/test_content_integrity_check.py
scripts/test_extract_crossrefs.py
scripts/test_paperfit_command.py
scripts/test_template_migrate.py
scripts/test_template_migration_priority.py
